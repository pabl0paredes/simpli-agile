<main class="map-area"
      data-sidebar-target="mapArea"
      data-controller="map"
      data-map-token-value="<%= ENV.fetch("MAPBOX_TOKEN", "") %>"
      data-map-initial-center-value="<%= @initial_center || "[-70.6371,-33.4378]" %>"
      data-map-initial-zoom-value="<%= @initial_zoom || 4 %>">

  <% mapbox_token = ENV.fetch("MAPBOX_TOKEN", "") %>

  <% if mapbox_token.present? %>
    <div id="map"
         class="map w-full h-full min-h-screen"
         data-map-target="mapContainer"></div>
  <% else %>
    <div class="map map--empty flex items-center justify-center w-full h-full min-h-screen p-6 text-center">
      <div>
        <strong>No se pudo cargar el mapa.</strong><br>
        Falta configurar la variable de entorno <code>MAPBOX_TOKEN</code>.
      </div>
    </div>
  <% end %>

  <div class="map-compare w-full h-full min-h-screen" data-map-target="compareContainer" hidden>
    <div class="map-compare__left" style="position:absolute;inset:0;" data-map-target="compareLeft"></div>
    <div class="map-compare__right" style="position:absolute;inset:0;" data-map-target="compareRight"></div>
  </div>

  <div class="map-split w-full h-full min-h-screen" data-map-target="splitContainer" hidden>
    <div class="map-split__top w-full h-full" data-map-target="splitTop"></div>
    <div class="map-split__bottom w-full h-full" data-map-target="splitBottom"></div>
  </div>

  <%# Botones flotantes (derecha) %>
  <div class="map-fab">

    <button type="button"
            class="map-fab__btn"
            aria-label="Gráfico"
            data-action="click->map#toggleDashboard"
            data-map-target="dashboardBtn">
      <i class="fa-solid fa-chart-bar"></i>
    </button>

    <button type="button"
            class="map-fab__btn"
            aria-label="Leyenda"
            data-action="click->map#toggleLegend"
            data-map-target="legendBtn"
            hidden>
      <i class="fa-solid fa-list"></i>
    </button>
  </div>

  <% if user_signed_in? %>
  <div class="mode-toggle"
      data-controller="mode-toggle"
      data-mode-toggle-mode-value="constructor"
      data-sidebar-target="modeToggle"
      hidden>
    <button type="button"
            class="mode-toggle__btn"
            data-mode-toggle-target="btn"
            data-mode="constructor"
            data-action="click->mode-toggle#select">
      Constructor
    </button>

    <button type="button"
            class="mode-toggle__btn"
            data-mode-toggle-target="btn"
            data-mode="comparador"
            data-action="click->mode-toggle#select">
      Comparador
    </button>
  </div>
  <% end %>


  <div class="map-panels-right">
    <div class="map-dashboard" data-map-target="dashboardPanel" hidden>
      <div class="map-dashboard__title" data-map-target="dashboardTitle" hidden></div>
      <div data-map-target="dashboardChart"></div>
      <div class="map-dashboard__co2" data-map-target="dashboardCo2" hidden>
        <div class="map-dashboard__co2-title">Emisiones CO₂ (auto)</div>
        <div class="map-dashboard__co2-row" data-map-target="dashboardCo2Single">
          <span class="map-dashboard__co2-value" data-map-target="dashboardCo2Value">—</span>
          <span class="map-dashboard__co2-unit">ton/año</span>
        </div>
        <div class="map-dashboard__co2-compare" data-map-target="dashboardCo2Compare" hidden>
          <div class="map-dashboard__co2-scenario">
            <span class="map-dashboard__co2-label">Esc. A</span>
            <span class="map-dashboard__co2-value" data-map-target="dashboardCo2ValueA">—</span>
            <span class="map-dashboard__co2-unit">ton/año</span>
          </div>
          <div class="map-dashboard__co2-scenario">
            <span class="map-dashboard__co2-label">Esc. B</span>
            <span class="map-dashboard__co2-value" data-map-target="dashboardCo2ValueB">—</span>
            <span class="map-dashboard__co2-unit">ton/año</span>
          </div>
        </div>

        <div class="map-dashboard__co2-title" style="margin-top:10px">Distancia promedio (auto)</div>
        <div class="map-dashboard__co2-row" data-map-target="dashboardAvgDistSingle">
          <span class="map-dashboard__co2-value" data-map-target="dashboardAvgDistValue">—</span>
          <span class="map-dashboard__co2-unit">km/viaje</span>
        </div>
        <div class="map-dashboard__co2-compare" data-map-target="dashboardAvgDistCompare" hidden>
          <div class="map-dashboard__co2-scenario">
            <span class="map-dashboard__co2-label">Esc. A</span>
            <span class="map-dashboard__co2-value" data-map-target="dashboardAvgDistValueA">—</span>
            <span class="map-dashboard__co2-unit">km/viaje</span>
          </div>
          <div class="map-dashboard__co2-scenario">
            <span class="map-dashboard__co2-label">Esc. B</span>
            <span class="map-dashboard__co2-value" data-map-target="dashboardAvgDistValueB">—</span>
            <span class="map-dashboard__co2-unit">km/viaje</span>
          </div>
        </div>

        <div class="map-dashboard__co2-title" style="margin-top:10px">Distribución de viajes por distancia</div>
        <div data-map-target="dashboardHistogram"></div>
      </div>
    </div>

    <div class="map-legend" data-map-target="legendPanel" hidden>
      <div class="map-legend__title">Leyenda</div>
      <div class="map-legend__items" data-map-target="legendItems"></div>
    </div>
  </div>
</main>
