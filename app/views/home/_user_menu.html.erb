<div
  class="user-menu"
  data-controller="user-menu"
  data-user-menu-open-value="false"
  data-user-menu-default-municipality-value="<%= user_signed_in? ? current_user.municipality_code.to_s : "" %>"
>
  <button type="button"
          class="user-menu__btn"
          aria-label="Usuario"
          data-action="click->user-menu#toggleMenu">

    <% if user_signed_in? %>
      <span class="user-menu__initial">
        <%= current_user.email.first.upcase %>
      </span>
    <% else %>
      <i class="fa-solid fa-circle-user"></i>
    <% end %>

  </button>

  <div class="user-menu__dropdown" data-user-menu-target="dropdown" hidden>
    <% if user_signed_in? %>

      <div class="user-menu__profile">
        <div class="user-menu__avatar">
          <%= current_user.email.first.upcase %>
        </div>
        <div class="user-menu__profile-info">
          <div class="user-menu__profile-label">Cuenta</div>
          <div class="user-menu__profile-email"><%= current_user.email %></div>
        </div>
      </div>

      <div class="user-menu__divider"></div>

      <div class="user-menu__default-municipality">
        <div class="user-menu__section-label">Comuna por defecto</div>
        <select class="user-menu__municipality-select"
                data-user-menu-target="municipalitySelect"
                data-action="change->user-menu#saveDefaultMunicipality">
          <option value="">Sin comuna por defecto</option>
        </select>
      </div>

      <div class="user-menu__divider"></div>

      <%= form_with url: destroy_user_session_path, method: :delete, data: { turbo: false }, class: "user-menu__signout-form" do %>
        <button type="submit" class="user-menu__signout-btn">
          <i class="fa-solid fa-arrow-right-from-bracket"></i>
          Cerrar sesión
        </button>
      <% end %>

    <% else %>

      <div class="user-menu__guest-header">
        <div class="user-menu__guest-icon">
          <i class="fa-solid fa-circle-user"></i>
        </div>
        <div class="user-menu__guest-label">Accede a tu cuenta</div>
      </div>

      <div class="user-menu__divider"></div>

      <%= link_to new_user_session_path,
            class: "user-menu__login-btn",
            data: { action: "click->user-menu#openModal",
                    turbo_frame: "auth_modal_frame" } do %>
        <i class="fa-solid fa-right-to-bracket"></i>
        Iniciar sesión
      <% end %>

      <%= link_to new_user_session_path,
            class: "user-menu__register-link",
            data: { action: "click->user-menu#openModal",
                    turbo_frame: "auth_modal_frame" } do %>
        ¿No tienes cuenta? <strong>Registrarse</strong>
      <% end %>

    <% end %>
  </div>

  <!-- Modal de autenticación -->
  <div class="auth-modal" data-user-menu-target="modal" hidden>
    <div class="auth-modal__backdrop" data-action="click->user-menu#closeModal"></div>

    <div class="auth-modal__panel" role="dialog" aria-modal="true">
      <button type="button" class="auth-modal__close" data-action="click->user-menu#closeModal">
        <i class="fa-solid fa-xmark"></i>
      </button>

      <div class="auth-modal__logo">
        <%= image_tag "Logo SimpliCity.png", alt: "SimpliCity" %>
      </div>
      <h2 class="auth-modal__title">Bienvenido</h2>
      <p class="auth-modal__subtitle">Inicia sesión para continuar</p>

      <turbo-frame id="auth_modal_frame"></turbo-frame>
    </div>
  </div>

</div>
