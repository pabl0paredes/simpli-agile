<div class="app-shell"
     data-controller="sidebar"
     data-sidebar-default-municipality-value="<%= user_signed_in? ? current_user.municipality_code.to_s : "" %>"
     data-user-signed-in="<%= user_signed_in? %>">
  <%= render "sidebar_primary" %>
  <%= render "sidebar_locator" %>
  <%= render "sidebar_simulator" %>
  <%= render "sidebar_collapse_btn" %>

  <%= render "user_menu" %>
  <%= render "help_modal" %>
  <%= render "publish_modal" %>

  <%= render "map_area" %>
  <%= render "pickcell_hint" %>
</div>
