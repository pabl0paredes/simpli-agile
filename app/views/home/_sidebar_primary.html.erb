<aside class="sidebar" data-sidebar-target="panel">
    <div class="sidebar__header-area">
      <div class="sidebar__brand">
        <%= image_tag "Logo SimpliCity.png", alt: "Logo SimpliCity" %>
      </div>
    </div>

    <div class="sidebar__top">
      <button
        type="button"
        class="sidebar__back-btn"
        data-sidebar-target="municipalityBackBtn"
        data-action="click->sidebar#clearMunicipality"
        <%= @initial_municipality ? "" : "hidden" %>
      >← <%= @initial_municipality ? @initial_municipality.name : "Volver a seleccionar comuna" %></button>

      <% if user_signed_in? %>
      <div class="sidebar__section" data-sidebar-target="comparatorSection" hidden>
        <div class="sidebar__label">ESCENARIO A</div>
        <select class="sidebar__select"
                data-sidebar-target="scenarioASelect"
                data-action="change->sidebar#scenarioAChanged"
                disabled>
          <option>Seleccionar escenario A...</option>
        </select>

        <div class="h-2.5"></div>

        <div class="sidebar__label">ESCENARIO B</div>
        <select class="sidebar__select"
                data-sidebar-target="scenarioBSelect"
                data-action="change->sidebar#scenarioBChanged"
                disabled>
          <option>Seleccionar escenario B...</option>
        </select>
      </div>


      <div class="sidebar__section" data-sidebar-target="compareModeSection" hidden>
        <div class="sidebar__label">MODO DE COMPARACIÓN</div>

        <div class="compare-modes">
          <button type="button"
                  class="compare-modes__btn is-active"
                  data-mode="delta"
                  data-action="click->sidebar#compareModeSelected"
                  aria-label="Delta"
                  data-tooltip="Diferencia entre escenarios">
            <i class="fa-solid fa-caret-up"></i>
          </button>

          <button type="button"
                  class="compare-modes__btn"
                  data-mode="split"
                  data-action="click->sidebar#compareModeSelected"
                  aria-label="Split"
                  data-tooltip="Pantalla dividida">
            <i class="fa-solid fa-table-columns"></i>
          </button>

          <button type="button"
                  class="compare-modes__btn"
                  data-mode="slider"
                  data-action="click->sidebar#compareModeSelected"
                  aria-label="Swipe"
                  data-tooltip="Deslizador comparativo">
            <i class="fa-solid fa-grip-lines-vertical"></i>
          </button>
        </div>
      </div>

      <div class="sidebar__section" data-sidebar-target="scenarioSection" hidden>
        <div class="sidebar__label">ESCENARIO</div>

        <div class="sidebar__row">
          <select class="sidebar__select"
                  data-sidebar-target="scenarioSelect"
                  data-action="change->sidebar#scenarioChanged"
                  disabled>
            <option>Seleccionar escenario...</option>
          </select>

          <button
            type="button"
            class="sidebar__icon-btn"
            data-sidebar-target="addScenarioBtn"
            data-action="click->sidebar#openCreateScenarioModal"
            title="Nuevo Escenario"
            hidden
          >+</button>
        </div>

        <div class="sidebar__hint sidebar__hint--center" data-sidebar-target="scenarioHint" style="display:none">
          Selecciona una comuna para ver tus escenarios
        </div>

        <div class="sidebar__scenario-actions">
          <button
            type="button"
            class="sidebar__success-btn"
            data-sidebar-target="saveScenarioBtn"
            data-action="click->sidebar#recalculateAccessibilities"
            disabled
            hidden
          >
            <i class="fa-solid fa-floppy-disk"></i> Guardar cambios
          </button>

          <button
            type="button"
            class="sidebar__danger-btn"
            data-sidebar-target="deleteScenarioBtn"
            data-action="click->sidebar#deleteScenario"
            hidden
          >
            <i class="fa-solid fa-trash"></i> Eliminar escenario
          </button>
        </div>
      </div>


      <% end %>


      <div class="sidebar__section" data-sidebar-target="regionSection">
        <div data-sidebar-target="regionSelectWrap" <% if @initial_municipality %>hidden<% end %>>
          <div class="sidebar__label">REGIÓN</div>
          <select class="sidebar__select" data-sidebar-target="regionSelect" data-action="change->sidebar#regionChanged">
            <option>Seleccionar región...</option>
          </select>
        </div>
        <button
          type="button"
          class="sidebar__back-btn"
          data-sidebar-target="regionBackBtn"
          data-action="click->sidebar#clearRegion"
          hidden
        >← Volver a seleccionar región</button>
      </div>

      <div class="sidebar__section" data-sidebar-target="municipalitySection">
        <div data-sidebar-target="municipalitySelectWrap" <% if @initial_municipality %>hidden<% end %>>
          <div class="sidebar__label">COMUNA</div>
          <select class="sidebar__select" data-sidebar-target="municipalitySelect" data-action="change->sidebar#municipalityChanged">
            <% if @initial_municipality %>
              <option value="<%= @initial_municipality.municipality_code %>" selected><%= @initial_municipality.name %></option>
            <% else %>
              <option>Seleccionar comuna...</option>
            <% end %>
          </select>
        </div>
      </div>

      <div class="sidebar__section" data-sidebar-target="normativeSection" hidden>
        <button
          type="button"
          class="sidebar__collapsible-label"
          data-action="click->sidebar#toggleNormativeLayers"
          data-sidebar-target="normativeToggleBtn"
          aria-expanded="false"
        >
          <span>CAPAS NORMATIVAS</span>
          <i class="fa-solid fa-chevron-right sidebar__collapsible-chevron"></i>
        </button>
        <div class="sidebar__layers" data-sidebar-target="normativeLayers" hidden>
          <button
            type="button"
            class="sidebar__layer-btn"
            data-norm-metric="norm_const"
            data-action="click->sidebar#selectLayer"
          >
            <i class="fa-solid fa-building-columns"></i> Constructibilidad remanente
          </button>
          <button
            type="button"
            class="sidebar__layer-btn"
            data-norm-metric="norm_footprint"
            data-action="click->sidebar#selectLayer"
          >
            <i class="fa-solid fa-expand"></i> Suelo remanente
          </button>
        </div>
      </div>

      <div class="sidebar__section" data-sidebar-target="opportunitySection" hidden>
        <div class="sidebar__label">OPORTUNIDAD</div>
        <select class="sidebar__select" data-sidebar-target="opportunitySelect" data-action="change->sidebar#opportunityChanged" disabled>
          <option>Seleccionar oportunidad</option>
        </select>
      </div>

      <div class="sidebar__section sidebar__no-data" data-sidebar-target="noDataSection" hidden>
        <p class="sidebar__no-data-msg">No hay datos cargados para esta comuna.</p>
      </div>

      <div class="sidebar__section" data-sidebar-target="layerSection" hidden>
        <div class="sidebar__label">VISUALIZACIÓN</div>

        <div class="sidebar__layers">
          <button
            type="button"
            class="sidebar__layer-btn"
            data-metric="surface"
            data-action="click->sidebar#selectLayer"
          >
            <i class="fa-solid fa-square"></i>Superficie
          </button>

          <button
            type="button"
            class="sidebar__layer-btn"
            data-metric="units"
            data-action="click->sidebar#selectLayer"
          >
            <i class="fa-solid fa-building"></i>Unidades
          </button>

          <button
            type="button"
            class="sidebar__layer-btn"
            data-layer="accessibility"
            data-action="click->sidebar#selectLayer"
          >
            <i class="fa-solid fa-person-walking"></i> Accesibilidad absoluta
          </button>

          <div class="sidebar__layer-btn-wrap">
            <button
              type="button"
              class="sidebar__layer-btn"
              data-layer="attractivity"
              data-action="click->sidebar#selectLayer"
            >
              <i class="fa-solid fa-chart-simple"></i> Accesibilidad relativa
            </button>
            <span class="sidebar__info-wrap">
              <i class="fa-solid fa-circle-info sidebar__info-icon"></i>
              <span class="sidebar__info-tooltip">Accesibilidad absoluta en relación a la demanda (viviendas)</span>
            </span>
          </div>
        </div>
      </div>

      <div class="sidebar__section" data-sidebar-target="accessibilityChoices" hidden>
        <div class="sidebar__label">MODO DE TRANSPORTE</div>
        <div class="sidebar__subchoices">
          <button
            type="button"
            class="sidebar__subchoice-btn"
            data-mode="walk"
            data-action="click->sidebar#selectAccessibilityMode"
          >
            Caminata
          </button>

          <button
            type="button"
            class="sidebar__subchoice-btn"
            data-mode="car"
            data-action="click->sidebar#selectAccessibilityMode"
          >
            Automóvil
          </button>
        </div>
      </div>


      <% if user_signed_in? %>
      <div
        class="sidebar__section"
        data-sidebar-target="locateSection"
        hidden
      >
        <div class="sidebar__label">HERRAMIENTAS DE ANÁLISIS</div>
        <div class="sidebar__tooltip-wrap" data-sidebar-target="locatorBtnWrap">
          <button
            type="button"
            class="sidebar__nav-btn"
            data-sidebar-target="locatorBtn"
            data-action="click->sidebar#toggleLocator"
          >
            <i class="fa-solid fa-location-dot"></i> Localizar Infraestructura
          </button>
          <span class="sidebar__tooltip">
            Debes crear un Escenario para localizar un proyecto de infraestructura
          </span>
        </div>
        <div class="sidebar__tooltip-wrap" data-sidebar-target="simulatorBtnWrap">
          <button
            type="button"
            class="sidebar__nav-btn"
            data-sidebar-target="simulatorBtn"
            data-action="click->sidebar#toggleSimulator"
          >
            <i class="fa-solid fa-people-group"></i> Agregar agentes
          </button>
          <span class="sidebar__tooltip">
            Simula la localización de agentes en el escenario actual
          </span>
        </div>
      </div>

      <div
        class="sidebar__no-access"
        data-sidebar-target="noAccessSection"
        hidden
      >
        <div class="sidebar__divider"></div>
        <p class="sidebar__no-data-msg">
          <i class="fa-solid fa-lock"></i><br>
          No tienes acceso a la versión completa para esta comuna.
        </p>
      </div>
      <% end %>

    </div>

    <div class="sidebar__config-panel" data-sidebar-target="configPanel" hidden>
      <div class="sidebar__config-panel__header">
        <span>CONFIGURACIÓN</span>
        <button type="button"
                class="sidebar__config-panel__close"
                data-action="click->sidebar#toggleConfigPanel"
                aria-label="Cerrar">
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
      <div class="sidebar__config-panel__label">PALETA DE COLORES</div>
      <div class="sidebar__config-panel__palettes">
        <button type="button" class="palette-picker__btn is-active"
                data-action="click->sidebar#selectPalette"
                data-sidebar-target="paletteBtn"
                data-palette="blue">
          <span class="palette-picker__swatch palette-picker__swatch--blue"></span>
          <span>Azul</span>
        </button>
        <button type="button" class="palette-picker__btn"
                data-action="click->sidebar#selectPalette"
                data-sidebar-target="paletteBtn"
                data-palette="verde">
          <span class="palette-picker__swatch palette-picker__swatch--verde"></span>
          <span>Verde</span>
        </button>
      </div>

      <div class="sidebar__config-panel__label" style="margin-top:14px">ESTILO DE MAPA</div>
      <div class="sidebar__config-panel__styles">
        <button type="button" class="map-style-picker__btn is-active"
                data-action="click->sidebar#selectMapStyle"
                data-sidebar-target="mapStyleBtn"
                data-style-id="streets-v12">
          <i class="fa-solid fa-map"></i><span>Clásico</span>
        </button>
        <button type="button" class="map-style-picker__btn"
                data-action="click->sidebar#selectMapStyle"
                data-sidebar-target="mapStyleBtn"
                data-style-id="satellite-streets-v12">
          <i class="fa-solid fa-satellite"></i><span>Satelital</span>
        </button>
        <button type="button" class="map-style-picker__btn"
                data-action="click->sidebar#selectMapStyle"
                data-sidebar-target="mapStyleBtn"
                data-style-id="navigation-day-v1">
          <i class="fa-solid fa-route"></i><span>Navegación</span>
        </button>
      </div>

      <div style="margin-top:14px; display:flex; align-items:center; justify-content:space-between; gap:8px;">
        <div class="sidebar__config-panel__label" style="margin-top:0; margin-bottom:0;">CALLES Y NOMBRES</div>
        <button type="button"
                class="config-toggle-row"
                style="width:auto; padding:0; flex-shrink:0;"
                data-action="click->sidebar#toggleStreetsOnTop"
                data-sidebar-target="streetsOnTopBtn"
                aria-pressed="false">
          <span class="config-toggle-track">
            <span class="config-toggle-thumb"></span>
          </span>
        </button>
      </div>
    </div>

    <div class="sidebar__bottom">
      <button class="sidebar__link" type="button"
              data-action="click->sidebar#toggleConfigPanel"
              data-sidebar-target="configBtn">
        <span class="sidebar__icon"><i class="fa-solid fa-gear"></i></span> Configuración
      </button>
      <button class="sidebar__link" type="button"
              data-action="click->sidebar#openHelp">
        <span class="sidebar__icon"><i class="fa-regular fa-circle-question"></i></span> Ayuda
      </button>
    </div>
</aside>
