<div class="modal" data-sidebar-target="publishModal" hidden>
  <div class="modal__backdrop" data-action="click->sidebar#closePublishModal"></div>

  <div class="modal__panel" role="dialog" aria-modal="true">
    <button type="button" class="modal__close" data-action="click->sidebar#closePublishModal">
      <i class="fa-solid fa-xmark"></i>
    </button>

    <div class="modal__title">Nuevo Escenario</div>

    <div class="modal__body">
      <div class="modal__parent-scenario">
        <span class="modal__parent-label">ESCENARIO PADRE:</span>
        <span class="modal__parent-name" data-sidebar-target="scenarioParentDisplay">—</span>
      </div>

      <div class="sidebar__label">NOMBRE DEL ESCENARIO</div>
      <input
        class="sidebar__input"
        type="text"
        placeholder="Ej: Proyectos Plan Centro 2027"
        data-sidebar-target="publishNameInput"
      />
      <div class="sidebar__hint sidebar__hint--muted">
        Este nombre se mostrará en tu lista de Escenarios.
      </div>
    </div>

    <div class="modal__actions">
      <button type="button" class="sidebar__secondary-btn" data-action="click->sidebar#closePublishModal">
        Cancelar
      </button>

      <button type="button" class="sidebar__primary-btn" data-action="click->sidebar#confirmCreateScenario">
        Crear Escenario
      </button>
    </div>
  </div>
</div>
