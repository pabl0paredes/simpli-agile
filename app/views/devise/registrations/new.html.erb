<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <%= image_tag "Logo SimpliCity.png", alt: "SimpliCity" %>
    </div>

    <h1 class="auth-title">Crear cuenta</h1>
    <p class="auth-subtitle">Para registrarte, contáctanos por correo</p>

    <div class="auth-modal-icon" style="margin-bottom: 12px;">✉️</div>
    <p class="auth-modal-text">
      El acceso a SimpliCity es por invitación. Escríbenos y te damos acceso:
    </p>
    <div class="auth-modal-email-box">contacto@simpli-city.cl</div>
    <a href="mailto:contacto@simpli-city.cl" class="auth-submit-btn" style="display:flex;align-items:center;justify-content:center;gap:8px;text-decoration:none;margin-bottom:20px;">
      <i class="fa-solid fa-envelope"></i> Enviar correo
    </a>

    <div class="auth-links">
      <%= link_to "← Volver al inicio de sesión", new_session_path(resource_name) %>
    </div>
  </div>
</div>
