<div class="auth-page">
  <div class="auth-card">
    <div class="auth-logo">
      <%= image_tag "Logo SimpliCity.png", alt: "SimpliCity" %>
    </div>

    <h1 class="auth-title">Recuperar contraseña</h1>

    <div class="auth-info-box">
      Ingresa tu correo y te enviaremos las instrucciones para restablecer tu contraseña.
    </div>

    <%= simple_form_for(resource, as: resource_name,
                                  url: password_path(resource_name),
                                  html: { method: :post }) do |f| %>
      <%= f.error_notification %>

      <div class="auth-field">
        <%= f.label :email, "Correo electrónico" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "tu@correo.cl" %>
      </div>

      <%= f.submit "Enviar instrucciones", class: "auth-submit-btn" %>
    <% end %>

    <div class="auth-links" style="margin-top: 20px;">
      <%= link_to "← Volver al inicio de sesión", new_session_path(resource_name) %>
    </div>
  </div>
</div>
